draw_frame() {
  offset=$1
  while IFS= read -r line; do
    if (( offset > 0 )); then
      printf "%*s%s\n" "$offset" "" "$line"
    else
      printf "%s\n" "${line: -offset}"
    fi
  done <<< "$car_art"
}

draw_car_with_exhaust() {
  exhaust_level=$1
  line_num=0
  exhaust_line1=""
  exhaust_line2=""
  exhaust_line3=""

  case $exhaust_level in
    1)  exhaust_line1="  ." ;;
    2)  exhaust_line1="  .." ;;
    3)  exhaust_line1="  .*." ;;
    4)  exhaust_line1="  .**."
        exhaust_line2="  ." ;;
    5)  exhaust_line1="  .***."
        exhaust_line2="  .." ;;
    6)  exhaust_line1="  .****."
        exhaust_line2="  .**" ;;
    7)  exhaust_line1="  .*****."
        exhaust_line2="  .***" ;;
    8)  exhaust_line1="  .**))**."
        exhaust_line2="  .***." ;;
    9)  exhaust_line1="  .**))))**."
        exhaust_line2="  .*)))*." ;;
    10) exhaust_line1="  .***))))***."
        exhaust_line2="  .*))))*."
        exhaust_line3="  .**." ;;
    11) exhaust_line1="  .****)))))****."
        exhaust_line2="  .**)))))**."
        exhaust_line3="  .***." ;;
    12) exhaust_line1="  .****))))))****."
        exhaust_line2="  .***))))***."
        exhaust_line3="  .***." ;;
    13) exhaust_line1="  .****))W))****."
        exhaust_line2="  .***))W))***."
        exhaust_line3="  .**)).**" ;;
    14) exhaust_line1="  .****)))WW)))****."
        exhaust_line2="  .***)))W)))***."
        exhaust_line3="  .**))))**." ;;
    15) exhaust_line1="  .*****)))WW))))*****."
        exhaust_line2="  .****)))WW)))****."
        exhaust_line3="  .***)))))))***." ;;
    16) exhaust_line1="  .****)))WW)))****. ~~"
        exhaust_line2="  .***)))WW)))***. ~~"
        exhaust_line3="  .**))))))**. ~" ;;
    17) exhaust_line1="    .***))WW))***. ~~~  POP!"
        exhaust_line2="    .**))WW))**. ~~~  POP!"
        exhaust_line3="    .*))))))*. ~~  POP!" ;;
    18) exhaust_line1="      .**))W))**. ~~~~  BANG!"
        exhaust_line2="      .*))W))*. ~~~  BANG!"
        exhaust_line3="      .*))))*. ~~  BANG!" ;;
    19) exhaust_line1="        .*)))*. ~~~~~  CRACK!"
        exhaust_line2="        .*))*.  ~~~~  CRACK!"
        exhaust_line3="        .*)). ~~~  CRACK!" ;;
    20) exhaust_line1="          .)*. ~~~~~~  BRATATATATA!"
        exhaust_line2="          .*  ~~~~~  BRATATATATA!"
        exhaust_line3="          .  ~~~~  BRATATATATA!" ;;
    21) exhaust_line1="            . ~~~~~~~  POP! POP!"
        exhaust_line2="              ~~~~~~  POP! POP!"
        exhaust_line3="              ~~~~  POP! POP!" ;;
    22) exhaust_line1="              ~~~~~~~~"
        exhaust_line2="              ~~~~~~"
        exhaust_line3="              ~~~" ;;
