draw_frame() {
  offset=$1
  while IFS= read -r line; do
    if (( offset > 0 )); then
      printf "%*s%s\n" "$offset" "" "$line"
    else
      printf "%s\n" "${line: -offset}"
    fi
  done <<< "$car_art"
}

animate() {
  direction="$1"
  width=35   # approximate car width

  if [ "$direction" = "right" ]; then
    for ((i=-width; i<cols; i+=2)); do
      clear
      draw_frame "$i"
      sleep 0.03
    done
  else
    for ((i=cols; i>-width; i-=2)); do
      clear
      draw_frame "$i"
      sleep 0.03
    done
  fi

  clear
  exit 0
}
car() {
  echo "$car_art"
}

status_art() {
  car
  cat <<EOF

GTI STATUS:
--------------
Engine:      1.8L 8V
Horsepower:  110 hp
0-100 km/h:  ~9 sec
Weight:      ~810 kg
Drive:       FWD
Mood:        Ready to rev
EOF
}

commit_art() {
  car
  cat <<EOF

*click*
Ignition turned.
History updated.
Boost staged.
EOF
}

case "$cmd" in
  status) status_art ;;
  push)   animate right ;;
  pull)   animate left ;;
  commit) commit_art ;;
  *)      car ;;
esac
